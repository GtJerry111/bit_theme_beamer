% ----------------
% Declare of Packages
% Confirmed in v2.1g(2026/06/26).
% Established in v2.1g(2026/06/26).
% ----------------
% CMD:: \usetikzlibrary - 调用 TikZ 库.
% ----------------
\usetikzlibrary{fadings,patterns}
% ----------------


\mode<presentation>


% ----------------
% Beamer Theme Title Page Layout
% Confirmed in v2.1g(2026/06/26).
% Established in v1.3c(2024/04/16).
% Updated in v2.1b(2025/10/06), v2.1c(2026/05/20), v2.1g(2026/06/26).
% ----------------
% 于 v2.1g(2026/06/26) 重新设计封面底栏图形与标题布局. 尺寸参数 \bit@wd@titleskip, \bit@ht@titlecurve, \bit@ht@title 等命名缩减且重新规范化; 标题布局: 不再用框图框住, 分隔线定位, 且无副标题时间距适配; 封面装饰: 取消单色大范围色块, 采用简洁流线型底栏图形 + 随机弧线模拟流星雨效果.
% ----------------
% CMD:: \newdimen   - 创建长度寄存器.
% CMD:: \newsavebox - 创建盒子.
% ----------------
% DIMEN:: Titlepage 左侧边距宽度 - wd@titleskip.
\newdimen\bit@wd@titleskip
\bit@wd@titleskip=16pt
% DIMEN:: Titlepage 底栏图形基线高度 - ht@titlecurve.
\newdimen\bit@ht@titlecurve
\bit@ht@titlecurve=.03\paperheight
% DIMEN:: Titlepage Logo+name 高度 - ht@titlelogo.
\newdimen\bit@ht@titlelogo
\bit@ht@titlelogo=.96\paperheight
% DIMEN:: Title 顶部高度 - ht@title.
\newdimen\bit@ht@title
\bit@ht@title=.75\paperheight
% DIMEN:: Title 宽度 - wd@title.
\newdimen\bit@wd@title
\bit@wd@title=\dimexpr\the\paperwidth-2\bit@wd@titleskip\relax
% DIMEN:: Author 宽度 - wd@author.
\newdimen\bit@wd@author
\bit@wd@author=.65\paperwidth
% DIMEN:: SepLine 宽度 - wd@titlesep.
\newdimen\bit@wd@titlesep
\bit@wd@titlesep=.08\paperwidth

% 封面样式定义.
\defbeamertemplate*{title page}{BIT title page theme}{%
  \begin{beamercolorbox}[wd=\paperwidth,ht=\paperheight]{}%
    % Author savebox.
    \newsavebox{\beamer@bit@authorbox}%
    \sbox{\beamer@bit@authorbox}{\parbox{\bit@wd@author}{%
      \setlength{\baselineskip}{10pt}%
      {\usebeamerfont{author}\insertauthor\par}%
      {\vskip8pt}%
      {\usebeamerfont{institute}\insertinstitute}%
    }}% savebox 存储
    % \settototalheight{\bit@len@authorheight}{\usebox{\beamer@bit@authorbox}}% 计算高度
    % \bit@len@authorheight=\dimexpr\bit@len@authorheight+0.036\paperwidth\relax% 补齐上下空白部分
    \begin{tikzpicture}[overlay]%
      % 限制绘图范围.
      \clip (0,0) rectangle (\paperwidth, \paperheight);%
      % 绘制 视觉识别标识.
      \node[anchor=north west, inner sep=0pt, outer sep=0pt]%
        at (\bit@wd@titleskip, \bit@ht@titlelogo) {\pgfuseimage{lg-name}};% logo-name
      \node[anchor=north east, inner sep=0pt, outer sep=0pt]%
        at (\paperwidth-22pt, \bit@ht@titlelogo+5pt) {\pgfuseimage{verify}};% verify 校训
      \node[anchor=south east, inner sep=0pt, outer sep=0pt, opacity=.3]%
        at (\paperwidth, 2*\bit@ht@titlecurve) {\pgfuseimage{landmark}};% 特色标识
      % 绘制 底栏图形.
      \fill[IntersperseC, path fading=south, fading transform={rotate=96}]%
        plot[smooth, domain=0:1.02, samples=30]%
        ({\x*\paperwidth}, {(.04+.15*pow(\x,4))*\paperheight})%
        -- (\paperwidth, \bit@ht@titlecurve) -- (0, \bit@ht@titlecurve) -- cycle;% 浅色渐变
      \shade[top color=PrimaryC, bottom color=IntersperseC]%
        plot[smooth, domain=0:.4, samples=30]%
        ({\x*\paperwidth}, {\bit@ht@titlecurve+.02*exp(-5*\x)*\paperheight})%
        -- (.4\paperwidth, \bit@ht@titlecurve) -- (0, \bit@ht@titlecurve) -- cycle;% 微下降过渡
      \fill[PrimaryC, path fading=north, fading transform={rotate=36}]%
        plot[smooth, domain=0:1.02, samples=30]%
        ({\x*\paperwidth}, {\bit@ht@titlecurve+.2*pow(\x,6)*\paperheight})%
        -- (1.02\paperwidth, 0) -- (0, 0) -- cycle;% 主色渐变(1.02 消除边缘空白)
      \draw[BackgroundC, line width=1pt, postaction={draw, yellow!90!green, path fading=south}]%
        plot[smooth, domain=0:1.02, samples=30]%
        ({\x*\paperwidth}, {\bit@ht@titlecurve+.2*pow(\x,6)*\paperheight});% 曲线渐变描边
      \pgfmathsetseed{10}% 设置随机短弧的种子
      \foreach \j in {0,...,9} {%
        \pgfmathsetmacro{\xori}{.6+pow(rnd,.4)*.3}% 从 .6\paperwidth 开始
        \pgfmathsetmacro{\xlen}{.06+.12*rnd}% 长度最小 .06\paperwidth
        \pgfmathsetmacro{\lw}{.4+1.2*rnd}% 线宽最小 .4pt
        \pgfmathsetmacro{\yoff}{rnd*.02}% 短弧下移幅度
        \pgfmathsetmacro{\amp}{.2*(1-\yoff/(.018))}% 振幅随 yoff 增大而减小
        \pgfmathsetmacro{\opa}{.2+.4*(1-\yoff/(.02))}% 透明度最低 .2
        \pgfmathsetmacro{\cidx}{int(rnd*2)}% 随机颜色
        \ifcase\cidx\def\mycol{BackgroundC}\or\def\mycol{IntersperseC}\fi%
        \draw[\mycol, path fading=west, line width=\lw pt, opacity=\opa]%
          plot[smooth, domain=\xori:{\xori+\xlen}, samples=10]%
          ({\x*\paperwidth}, {(.03-\yoff+\amp*pow(\x,6))*\paperheight});%
      }% 随机短弧(流星雨效果)
      % 绘制 Titlepage 元素.
      \node[anchor=north west, inner sep=0pt, outer sep=0pt, text width=\bit@wd@title]%
        (TitleText) at (\bit@wd@titleskip, \bit@ht@title) {%
        {\usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\par}%
      };% title 文字
      \node[anchor=north west, inner sep=0pt, outer sep=0pt, text width=\bit@wd@author]%
        (SubText) at ([yshift=-8pt]TitleText.south west) {%
        {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle}%
      };% subtitle 文字
      % 分隔线基准: 有 subtitle 用 SubText, 否则用 TitleText.
      \ifx\insertsubtitle\@empty%
        \coordinate (SepAnchor) at (TitleText.south west);%
      \else
        \coordinate (SepAnchor) at (SubText.south west);%
      \fi%
      \fill[IntersperseC, path fading=east]%
        ([yshift=-14pt]SepAnchor) ++(\bit@wd@titlesep, 0) coordinate (SepExt)%
        rectangle ++(2\bit@wd@titlesep, -2pt);% 分隔线延伸段
      \shade[left color=PrimaryC, right color=BackgroundC] ([yshift=-14pt]SepAnchor) coordinate (SepLine)%
        -- ++(\bit@wd@titlesep, 0) arc (90:0: 2pt) -- ++(-\bit@wd@titlesep-2pt, 0) -- cycle;% 分隔线
      \node[anchor=north west, inner sep=0pt, outer sep=0pt] at ([yshift=-12pt]SepLine) (AuthorText)% 
        {\usebox{\beamer@bit@authorbox}};% author | institute 文字
      \node[anchor=south west, inner sep=0pt, outer sep=0pt]%
        at (\bit@wd@titleskip, 2\bit@ht@titlecurve) {\usebeamerfont{date}\insertdate};% date 文字
      % \node[anchor=south west,draw] at (0, 0) {00};
    \end{tikzpicture}%
  \end{beamercolorbox}%
}
\setbeamertemplate{title page}[BIT title page theme]
% ----------------


