% Beamer Theme Frametitle Layout
% Confirmed in v2.1c(2026/05/20).
% Established in v1.0a(2021/12/03).
% Updated in v1.2a(2022/03/10), v1.3b(2022/04/13), v1.3c(2024/04/16), v2.1b(2025/10/06), v2.1c(2026/05/20).
% ----------------
% 于 v2.1b(2025/10/06) 优化 Frametitle 纵向间距.
% 于 v2.1c(2026/05/20) 缩减 DIMEN, BOX 等变量名的长度 (由 beamer@scu@xxx 改为 scu@xxx, 更直观).
% ----------------
% FORMAT:: frametitle | framesubtitle.
% ----------------
% 设置 Frametitle 主题模板.
\defbeamertemplate*{frametitle}{SCU frametitle theme}{%
  \vskip-2pt% 消除 Headline 和 Frametitle 间空白距离
  \ifx\insertframesubtitle\@empty%
    \begin{beamercolorbox}[wd=\paperwidth, ht=2.2ex,%
      leftskip=\scu@wd@headlineskip]{}%{frametitle}
      \usebeamerfont{frametitle}%
      \usebeamercolor[fg]{frametitle}%
      \insertframetitle%
    \end{beamercolorbox}%
  \else%
    \begin{beamercolorbox}[wd=\paperwidth, ht=2.2ex,%
      leftskip=\scu@wd@headlineskip]{}%{frametitle}
      \usebeamerfont{frametitle}%
      \usebeamercolor[fg]{frametitle}%
      \insertframetitle~%
      \textcolor{SecondaryAuxiliaryC}{\rule[-.2ex]{.08em}{1.8ex}}~%
      \usebeamerfont{framesubtitle}%
      \usebeamercolor[fg]{framesubtitle}%
      \insertframesubtitle%
    \end{beamercolorbox}%
  \fi%
}
\setbeamertemplate{frametitle}[SCU frametitle theme]
