% 页眉样式定义.
\newdimen\scu@len@secbarY% 章节导航栏 y 值
\newdimen\scu@len@subsecbarY% 小节导航栏 y 值
\newdimen\scu@len@miniframesX% 迷你帧 x 值
\newdimen\scu@len@miniframesY% 迷你帧 y 值
\def\beamer@scu@headline{%
  % 填充内容盒子.
  \setbox\scu@box@secbar=\hbox{%
    \insert@secbar{\scu@wd@headlineskip}}% 设置章节导航栏盒子, 内容右对齐
  \setbox\scu@box@subsecbar=\hbox{\insert@subsecbar}% 设置小节导航栏盒子
  % 设置 dimen.
  \scu@wd@subsecbar=\wd\scu@box@subsecbar% 设置小节导航栏宽度
  \scu@len@secbarY=\dimexpr.5\scu@ht@headline%
    -.5\ht\scu@box@secbar+.25\dp\scu@box@secbar\relax% 设置章节导航栏 y 值
  \scu@len@subsecbarY=\dimexpr.5\scu@ht@headline+1pt%
    -.5\ht\scu@box@subsecbar+.5\dp\scu@box@subsecbar\relax% 设置小节导航栏 y 值
  % 使用 picture 环境定位及绘制 Headline.
  \begin{picture}(0, 0)%
    \put(0, 0){\usebox{\scu@box@headlineBg}}% 绘制 Headline 底图
    \put(\paperwidth, \scu@len@secbarY){%
      \makebox[0pt][r]{\box\scu@box@secbar}}% 绘制章节栏水平导航
    \put(\scu@wd@headlineskip, \scu@len@subsecbarY){%
      \box\scu@box@subsecbar}% 绘制小节导航栏
    % 迷你帧跟随模式.
    \if\EqualOptionsBeamer{Miniframes}{follow}%
      \setbox\scu@box@miniframes=\hbox{\parbox{%
        \dimexpr\scu@wd@sectotitleline-\scu@wd@subsecbar\relax}{%
          \insert@subsecminiframes{3.6pt}{1.6pt}}}% 设置迷你帧盒子
      \scu@len@miniframesX=\dimexpr\scu@wd@headlineskip%
        +\scu@wd@subsecbar+2.4pt\relax% 设置迷你帧 x 值
      \scu@len@miniframesY=\dimexpr.5\scu@ht@headline+1pt-.75pt%
        -.5\ht\scu@box@miniframes+.5\dp\scu@box@miniframes\relax% 设置迷你帧 y 值
      \put(\scu@len@miniframesX, \scu@len@miniframesY){%
        \box\scu@box@miniframes}% 绘制小节迷你帧
    % 迷你帧分离模式.
    \else\if\EqualOptionsBeamer{Miniframes}{separate}%
      \setbox\scu@box@miniframes=\hbox{%
        \insert@subsecminiframes{3.6pt}{1.6pt}}% 设置迷你帧盒子
      \scu@len@miniframesX=\dimexpr\paperwidth%
        -\scu@wd@headlineskip+1.6pt\relax% 设置迷你帧 x 值
      \put(\scu@len@miniframesX, -6){%
        \makebox[0pt][r]{\box\scu@box@miniframes}}% 绘制小节迷你帧
    % 迷你帧取消模式.
    \else\if\EqualOptionsBeamer{Miniframes}{none}%
      \relax%
    \fi\fi\fi%
  \end{picture}%
}

% 设置 Headline 主题模板.
\defbeamertemplate*{headline}{SCU headline theme}{%
  \begin{beamercolorbox}[wd=\paperwidth, ht=\scu@ht@headline]{}%
    \beamer@scu@headline%
  \end{beamercolorbox}%
}
\setbeamertemplate{headline}[SCU headline theme]
