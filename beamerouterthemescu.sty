% 设置 Footline 主题模板.
\defbeamertemplate*{footline}{SCU footline theme}{%
  \begin{beamercolorbox}[wd=\paperwidth, ht=\scu@ht@footline, dp=0pt]{}%
    \beamer@scu@framenumber% 优先调用计数器设置
    \beamer@scu@progressbar{AuxiliaryC}{PrimaryC}{IntersperseC}%
    \beamer@scu@footline%
  \end{beamercolorbox}%
}
\setbeamertemplate{footline}[SCU footline theme]
