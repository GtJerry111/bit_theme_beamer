% DIMEN:: Headline 高度 - ht@headline.
\newdimen\scu@ht@headline
\scu@ht@headline=13pt
% DIMEN:: Headline 页边距宽度 - wd@headlineskip.
\newdimen\scu@wd@headlineskip
\scu@wd@headlineskip=9pt
% DIMEN:: 章节导航栏宽度 - wd@secbar.
\newdimen\scu@wd@secbar
\if\EqualOptionsBeamer{LanguageMode}{cn}%
  \scu@wd@secbar=0.64\paperwidth%
\else\if\EqualOptionsBeamer{LanguageMode}{en}%
  \scu@wd@secbar=0.52\paperwidth%
\fi\fi
% DIMEN:: 小节-标题分隔线宽度 - wd@sectotitleline.
\newdimen\scu@wd@sectotitleline
\scu@wd@sectotitleline=\dimexpr\the\paperwidth-\scu@wd@secbar-30pt\relax
% DIMEN:: 小节导航栏宽度 - wd@sectotitleline.
\newdimen\scu@wd@subsecbar
\scu@wd@subsecbar=0pt

% BOX:: 章节导航栏盒子 - box@secbar.
\newbox\scu@box@secbar
% BOX:: 小节导航栏盒子 - box@subsecbar.
\newbox\scu@box@subsecbar
% BOX:: 迷你帧盒子 - box@miniframes.
\newbox\scu@box@miniframes

% 定义 Curve 函数.
%% 参考::
%% https://www.desmos.com/calculator/b2ojducp8y
\def\RCurveT#1{(2+2^(sin(3*(#1))))/2}% r=(2+2^(sin(3θ)))/2
\def\RCurveTP#1{(2+2^(sin(3*(#1+180))))/2}% r=(2+2^(sin(3*(θ+π))))/2
\def\RCurveF#1{(2+2^(sin(5*(#1))))/2}% r=(2+2^(sin(5θ))/2
\def\RCurveFP#1{(2+2^(sin(5*(#1+180))))/2}% r=(2+2^(sin(5*(θ+π))))/2
\def\ycut{0.88}%
\def\RCurveX#1#2{((\csname RCurve#1\endcsname{#2}*cos(#2))/(2-\ycut))}% 定位 x
\def\RCurveYU#1#2{((\csname RCurve#1\endcsname{#2}*sin(#2)-\ycut)/(2-\ycut))}% 定位 y, 图形在 y 轴上方
\def\RCurveYD#1#2{((\csname RCurve#1\endcsname{#2}*sin(#2)+\ycut)/(2-\ycut))}% 定位 y, 图形在 y 轴下方

% SAVEBOX:: TikZ Headline 底图盒子 - box@headlinebg.
\newsavebox{\scu@box@headlineBg}%
\sbox{\scu@box@headlineBg}{%
  \begin{tikzpicture}%
    % 定义 章节栏 辅助绘图节点.
    \coordinate (章节栏-右上) at (\the\paperwidth, 0);%
    \coordinate (章节栏-右下) at (\the\paperwidth, -\scu@ht@headline);%
    \coordinate (章节栏-左上) at ([xshift=-\scu@wd@secbar]章节栏-右上);%
    \coordinate (章节栏-左下) at ([xshift=-\scu@wd@secbar]章节栏-右下);%
    % 限制绘图范围.
    \clip (0,0) rectangle (章节栏-右下);%
    % 绘制 章节栏.
    \shade[top color=IntersperseC, bottom color=AuxiliaryC]%
      (章节栏-左上) -- (章节栏-左下)%
      -- plot[smooth, domain=270:216, samples=40]%
        ({\scu@ht@headline*\RCurveX{T}{\x}+\the\paperwidth-\scu@wd@secbar},%
        {\scu@ht@headline*\RCurveYD{T}{\x}}) -- cycle;% 渐变装饰
    \fill[PrimaryC] (章节栏-右上) -- (章节栏-右下) -- (章节栏-左下)%
      -- plot[smooth, domain=270:216, samples=40]%
        ({\scu@ht@headline*\RCurveX{FP}{\x}+\the\paperwidth-\scu@wd@secbar},%
        {\scu@ht@headline*\RCurveYD{FP}{\x}}) -- cycle;% 章节栏背景
    % 定义 横向分隔线 辅助绘图节点.
    \coordinate (横向分隔线-左下) at (0, -\scu@ht@headline);%
    \coordinate (横向分隔线-左上) at ([yshift=2pt]横向分隔线-左下);%
    \coordinate (横向分隔线-右下) at (\scu@wd@sectotitleline, -\scu@ht@headline);%
    % 绘制 小节与标题间横向分隔线.
    \shade[left color=PrimaryC, right color=IntersperseC]%
      (横向分隔线-右下) -- (横向分隔线-左下) -- (横向分隔线-左上)%
      -- plot[smooth, domain=90:36, samples=18]%
        ({2pt*\RCurveX{TP}{\x}+\scu@wd@sectotitleline},%
        {2pt*\RCurveYU{TP}{\x}-\scu@ht@headline}) -- cycle;% 横向分隔线
  \end{tikzpicture}%
}%

% 插入章节栏水平导航.
\def\insert@secbar#1{%
  % #1:: en LanguageMode 下尾部距离.
  \usebeamerfont{section in head/foot}%
  \usebeamercolor[fg]{section in head/foot}%
  \if\EqualOptionsBeamer{LanguageMode}{cn}%
    \insertsectionnavigationhorizontal{\scu@wd@secbar}{}{}%
  \else\if\EqualOptionsBeamer{LanguageMode}{en}%
    \insertsectionhead\hspace*{#1}%
  \fi\fi%
}

% 插入小节标题.
\def\insert@subsecbar{%
  \usebeamerfont{subsection in head/foot}%
  \usebeamercolor[fg]{subsection in head/foot}%
  \insertsubsectionhead%
}

% 插入小节迷你帧 [采用 \slideentry 方式生成].
%% 参考::
%% Beamer Class beamerbasenavigation.sty - definition of \slideentry
%% https://tex.stackexchange.com/questions/170122/simple-mini-frames-under-frame-title-beamer
%% https://tex.stackexchange.com/questions/23151/beamer-infolines-outer-theme-with-miniframe-bullets-only-for-the-current-section
%% https://tex.stackexchange.com/questions/308343/how-to-create-mini-sections-mini-subsections-and-mini-frames-in-beamer-presenta
\def\insert@subsecminiframes#1#2{%
  % #1:: baselineskip.
  % #2:: mini-frames space.
  \setlength{\baselineskip}{#1}% 调整 baselineskip 以减小行间距
  % \usebeamerfont{subsection in head/foot}% 注释 与上行冲突
  \usebeamercolor[fg]{subsection in head/foot}%
  \def\sectionentry##1##2##3##4##5{}%
  \def\slideentry##1##2##3##4##5##6{%
    %section number, subsection number, slide number, first/last frame, last subsection, part number
    \ifnum##6=\c@part\ifnum##1=\c@section\ifnum##2>0\ifnum##3>0%
      \beamer@link(##4){%
        \usebeamerfont{mini frames}%
        \ifnum\c@subsection=##2%
          \usebeamercolor{mini frame}%
          \ifnum\c@subsectionslide<##3%
            \usebeamertemplate{mini frame in current subsection}%
            \hskip#2%\beamer@minisliderowhilight%
          \else%
            \usebeamertemplate{mini frame}%
            \hskip#2%\beamer@minislidehilight%
          \fi%
        \fi}%
        \hskip0pt% 避免换行导致超链接中断
    \fi\fi\fi\else%
      \fakeslideentry{##1}{##2}{##3}{##4}{##5}{##6}%
    \fi%
    \ignorespaces%
  }%
  \setbox\beamer@sectionbox=\hbox{}%
  \hskip0pt\dohead%
  \box\beamer@sectionbox%
}
