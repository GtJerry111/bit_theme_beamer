% Beamer Theme Footline Layout
% Confirmed in v2.1c(2026/05/20).
% Established in v1.0a(2021/12/03).
% Updated in v1.2a(2022/03/10), v1.3a(2022/03/16), v1.3b(2022/04/13), v1.3c(2024/04/16), v1.3e(2024/10/31), v2.1b(2025/10/06), v2.1c(2026/05/20).
% ----------------
% 于 v1.3c(2024/04/16) 与 Footline TikZ 绘图部分合并, 强化代码关联度.
% 于 v2.1b(2025/10/06) 更改 Tikz 节点描述为中文, 更直观; 使用 picture 环境替换此前所用 tikz 环境定位及绘制 Footline.
% 于 v2.1c(2026/05/20) 缩减 DIMEN, BOX 等变量名的长度 (由 beamer@scu@xxx 改为 scu@xxx, 更直观), Logo 相关长度重新调整, 且支持自定义 Logo 区宽度; 使用曲线函数重绘原直角梯形图形, 部分采用渐变过渡.
% ----------------
% CMD:: \newdimen   - 创建长度寄存器.
% CMD:: \newcount   - 创建计数器.
% CMD:: \newbox - 创建盒子.
% CMD:: \newsavebox - 创建盒子.
% ----------------
% FORMAT:: NAME of SCU | author | short title | navigation tool | framenumber.
% ----------------
% DIMEN:: Footline 高度 - ht@footline.
\newdimen\scu@ht@footline
\scu@ht@footline=12pt
% DIMEN:: Logo 宽度 - wd@Logobar.
\newdimen\scu@wd@Logobar
\scu@wd@Logobar=\beamer@scu@LogoWidth\relax
% DIMEN:: Acrobat 页面跳转页码导航栏宽度 - wd@pagebar.
\newdimen\scu@wd@pagebar
% DIMEN:: ProgressBar 空白 - wd@pagebarbk.
\newdimen\scu@wd@pagebarbk
\scu@wd@pagebarbk=\dimexpr\scu@wd@Logobar+16pt\relax
% DIMEN:: ProgressBar 宽度 - wd@probar.
\newdimen\scu@wd@probar
\scu@wd@probar=\dimexpr\the\paperwidth-\scu@wd@pagebarbk\relax
% DIMEN:: ProgressBar auxiliary dimension - len@probartmp.
\newdimen\scu@len@probartmp

% COUNT:: 当前帧页码(正文/附录) - currentframe.
\newcount\scu@count@currentframe
% COUNT:: 当前总页码(正文/附录) - totalframe.
\newcount\scu@count@totalframe

% BOX:: 标题导航栏盒子 - box@titlebar.
\newbox\scu@box@titlebar
% BOX:: 页码导航栏盒子 - box@pagebar.
\newbox\scu@box@pagebar
% BOX:: 功能导航栏盒子 - box@navbar.
\newbox\scu@box@navbar

% SAVEBOX:: TikZ Footline 底图盒子 - box@footlineBg.
\newsavebox{\scu@box@footlineBg}%
\sbox{\scu@box@footlineBg}{%
  \begin{tikzpicture}%
    % 定义 Logo 辅助绘图节点.
    \coordinate (Logo-左上) at (0, \scu@ht@footline);%
    \coordinate (Logo-右上) at (\scu@wd@Logobar, \scu@ht@footline);%
    \coordinate (Logo-右下) at (\scu@wd@Logobar, 0);%
    % 限制绘图范围.
    \clip (Logo-左上) rectangle (\the\paperwidth, 0);%
    % 绘制 Logo.
    \shade[top color=AuxiliaryC, bottom color=IntersperseC]%
      (Logo-右下) -- (Logo-右上)%
      -- plot[smooth, domain=90:36, samples=40]%
        ({\scu@ht@footline*\RCurveX{TP}{\x}+\scu@wd@Logobar},%
        {\scu@ht@footline*\RCurveYU{TP}{\x}}) -- cycle;% 渐变装饰
    \fill[PrimaryC] (0, 0) -- (Logo-左上) -- (Logo-右上)%
      -- plot[smooth, domain=90:36, samples=40]%
        ({\scu@ht@footline*\RCurveX{F}{\x}+\scu@wd@Logobar},%
        {\scu@ht@footline*\RCurveYU{F}{\x}}) -- cycle;% Logo 背景
    \node[inner sep=0pt, outer sep=0pt] at (25pt, 6pt) {\pgfuseimage{lg}};% Logo
    % 定义 进度条 辅助绘图节点.
    \coordinate (进度条-左上) at (\scu@wd@pagebarbk, \scu@ht@footline);%
    \fill[IntersperseC] (进度条-左上) -- ++ (.2pt, 0) -- ++ (0, -3pt) -- ++ (-.2pt, 0)%
      -- plot[smooth, domain=270:216, samples=18]%
        ({3pt*\RCurveX{FP}{\x}+\scu@wd@pagebarbk},%
        {3pt*\RCurveYD{FP}{\x}+\scu@ht@footline}) -- cycle;% 进度条 装饰
  \end{tikzpicture}%
}%

% SAVEBOX:: TikZ ProgressBar 装饰盒子 - box@progressbarDc.
\newsavebox{\scu@box@progressbarDc}%
\sbox{\scu@box@progressbarDc}{%
  \begin{tikzpicture}%
    % 限制绘图范围.
    \clip (1.5pt, .01pt) rectangle (-5pt, -3pt);%
    % 绘制 进度条 装饰.
    \shade[left color=IntersperseC, right color=BackgroundC] (0, -2.99pt)%
      -- plot[smooth, domain=270:210, samples=18]%
        ({3pt*\RCurveX{FP}{\x}}, {3pt*\RCurveYD{FP}{\x}+.01pt})%
      -- (0, .01pt) arc (90:-90: 1.5pt) -- cycle;% 进度条 色块
    \draw[BackgroundC, line width=.3pt] (.8pt, -3.3pt) arc (0:84: .8pt and .3pt)%
      -- plot[smooth, domain=270:210, samples=18]% 
        ({3pt*\RCurveX{FP}{\x}}, {3pt*\RCurveYD{FP}{\x}})%
      arc (260:220: 1.5pt and .6pt);% 进度条 装饰
  \end{tikzpicture}%
}%

% 设置帧页码计数器(正文/附录).
\def\beamer@scu@framenumber{%
  \ifbeamer@inappendix% 附录帧取附录帧页码
    \scu@count@currentframe=\insertframenumberinappendix%
    \scu@count@totalframe=\insertappendixframenumber%
  \else% 正文帧取除开附录帧页码
    \scu@count@currentframe=\insertframenumber%
    \scu@count@totalframe=\insertmainframenumber%
  \fi%
}

% 插入帧页码.
\def\insert@framenumber{% 页码显示为"x / total"
  \usebeamerfont{framenumber in head/foot}%
  \usebeamercolor[fg]{framenumber in head/foot}%
  \usebeamertemplate*{page number in head/foot}%
}

% 插入带有 Acrobat 页面跳转按钮的页码.
\def\insert@framenumberwithbutton{%
  % \raisebox{0pt}[0pt][0pt]{\rlap{xx}xx}%
  \Acrobatmenu{GoToPage}{%
    \usebeamerfont{framenumber in head/foot}%
    \usebeamercolor[fg]{framenumber in head/foot}%
    \the\scu@count@currentframe}%
  \usebeamerfont{framenumber in head/foot}%
  \textcolor{SecondaryAuxiliaryC}{~\scalebox{1.33}[0.9]{\faCaretRight}\,\the\scu@count@totalframe}%
}

% Compute Navigation Tool num.
\if\EqualOptionsBeamer{NavigationTool}{none}%
  \relax%
\else%
  \StrSubstitute{\beamer@scu@NavigationTool}{-}{, }[\NavigationTool@group]
  \StrCount{\NavigationTool@group}{,}[\NavigationTool@len]
\fi%
% 插入 Navigation Tools.
\def\insert@footnavigationtool#1#2{%
  % #1:: 组内工具间距.
  % #2:: 组间工具间距.
  \usebeamercolor[fg]{palette quaternary}%\tiny%
  \foreach \group [count=\c] in \NavigationTool@group {%
    \IfInteger{\group}{%
      \ifnum\group=1%
        % 上一小节 | 当前小节开始 | 下一小节.
        \setfontscu{5}%
        \hyperlinksubsectionendprev{\faCaretLeft}\hskip#1%
        \hyperlinksubsectionstart{\faStream}\hskip#1%
        \hyperlinksubsectionstartnext{\faCaretRight}%
      \else\ifnum\group=2%
        % 初始页 | 查找 | 结尾页.
        \setfontscu{5}%
        \hyperlinkpresentationstart{\faCaretLeft\hskip-.05em\faCaretLeft}\hskip#1%
        \setfontscu{4.5}%
        \Acrobatmenu{Find}{\faSearch}\hskip#1%
        \setfontscu{5}%
        \hyperlinkpresentationend{\faCaretRight\hskip-.05em\faCaretRight}%
      \else\ifnum\group=3%
        % 上一视图 | 全屏 | 下一视图.
        \setfontscu{4.5}%
        \Acrobatmenu{GoBack}{\faReply}\hskip#1%
        \setfontscu{5}%
        \Acrobatmenu{FullScreen}{\faExpand}\hskip#1%
        \setfontscu{4.5}%
        \Acrobatmenu{GoForward}{\reflectbox{\faReply}}%
      \fi\fi\fi%
      \ifnum\c<\numexpr\NavigationTool@len+1\relax%
        \hskip#2%
      \fi%
    }{%
      \PackageError{beamerthemescu}{%
        Improper usage: `\protect\usetheme[...]{scu}' option [NavigationTool=xxx].\MessageBreak%
        `NavigationTool' should be set to `nagate'\MessageBreak%
        or an option composed of numbers 1 to 3 and the symbol `-', such as `2', `1-3', and `1-2-3'%
      }{%
        `NavigationTool' should be set to `nagate' or an option composed of numbers 1 to 3 and the symbol `-', such as `2', `1-3', and `1-2-3'%
      }%
    }%
  }%
}

% 页脚样式定义.
\newdimen\scu@len@titlebarY% 标题导航栏 y 值
\newdimen\scu@len@pagebarX% 页码导航栏 x 值
\newdimen\scu@len@pagebarY% 页码导航栏 y 值
\newdimen\scu@len@navbarX% 功能导航栏 x 值
\newdimen\scu@len@navbarY% 功能导航栏 y 值
\def\beamer@scu@footline{%
  % 填充内容盒子.
  \setbox\scu@box@titlebar=\hbox{%
    \usebeamerfont{author in head/foot}%
    \usebeamercolor[fg]{author in head/foot}%
    \insertshortauthor\,%
    \usebeamerfont{title in head/foot}%
    \textcolor{SecondaryAuxiliaryC}{·\,}%
    \usebeamercolor[fg]{title in head/foot}%
    \insertshorttitle%
  }% 设置页脚标题导航栏盒子
  \setbox\scu@box@pagebar=\hbox{%
    \insert@framenumberwithbutton}% 设置页脚页码导航栏盒子
  % 设置 dimen.
  \scu@wd@pagebar=\wd\scu@box@pagebar% 设置页码导航栏宽度
  \scu@len@secbarY=\dimexpr.5\scu@ht@footline-1.5pt%
    -.5\ht\scu@box@titlebar+.25\dp\scu@box@titlebar\relax% 设置标题导航栏 y 值
  \scu@len@pagebarX=\dimexpr\paperwidth%
    -\scu@wd@headlineskip\relax% 设置页码导航栏 x 值
  \scu@len@pagebarY=\dimexpr.5\scu@ht@footline-1.5pt%
    -.5\ht\scu@box@pagebar+.25\dp\scu@box@pagebar\relax% 设置页码导航栏 y 值
  % 使用 picture 环境定位及绘制 Footline.
  \begin{picture}(0, 0)%
    \put(0, 0){\usebox{\scu@box@footlineBg}}% 绘制 footline 底图
    \put(\scu@wd@pagebarbk, \scu@len@secbarY){\box\scu@box@titlebar}% 绘制 标题
    \put(\scu@len@pagebarX, \scu@len@pagebarY){%
      \makebox[0pt][r]{\box\scu@box@pagebar}}% 绘制带有 Acrobat 页面跳转按钮的页码
    \if\EqualOptionsBeamer{NavigationTool}{none}%
      \relax%
    \else%
      \setbox\scu@box@navbar=\hbox{%
        \insert@footnavigationtool{1.6pt}{4.2pt}}% 设置功能导航栏盒子
      \scu@len@navbarX=\dimexpr\scu@len@pagebarX%
        -\scu@wd@pagebar-6pt\relax% 设置功能导航栏 x 值
      \scu@len@navbarY=\dimexpr.5\scu@ht@footline-1.5pt%
        -.5\ht\scu@box@navbar+.25\dp\scu@box@navbar\relax% 设置功能导航栏 y 值
      \put(\scu@len@navbarX, \scu@len@navbarY){%
        \makebox[0pt][r]{\box\scu@box@navbar}}% 绘制 Navigation Tools
    \fi%
  \end{picture}%
}

% 进度条样式定义.
\def\beamer@scu@progressbar#1#2#3{%
  % #1:: 未放映部分颜色.
  % #2:: 已放映部分颜色.
  % #3:: 辅助色.
  \scu@len@probartmp=\scu@wd@probar%
  \divide\scu@len@probartmp by 1000%
  \multiply\scu@len@probartmp by \scu@count@currentframe%
  \divide\scu@len@probartmp by \scu@count@totalframe%
  \multiply\scu@len@probartmp by 1000%
  \begin{tikzpicture}[very thin, overlay, remember picture]%
    % 绘图辅助节点定义.
    \coordinate (SouthEast) at (current page.south east);% dong南节点
    \coordinate (ProBar) at (\scu@wd@pagebarbk, 9pt);% 初始节点
    % 限制绘图范围.
    \clip (ProBar) rectangle (\the\paperwidth, \scu@ht@footline);%
    % 绘制 进度条.
    \fill[#1] (ProBar) rectangle ++ (\scu@wd@probar, 3pt);% 未放映部分
    \shade[left color=#3, right color=#2] (ProBar)%
      -- ++ (\scu@len@probartmp, 0) arc (0:90: 3pt)%
      -- ([yshift=3pt]ProBar) -- cycle;% 已放映部分
    \node[inner sep=0pt, outer sep=0pt] at%
      ([xshift=\dimexpr\scu@len@probartmp-1.75pt\relax, yshift=1.5pt]ProBar)%
      {\usebox{\scu@box@progressbarDc}};% 装饰线
  \end{tikzpicture}%
}

