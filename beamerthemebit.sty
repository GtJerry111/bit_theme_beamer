% ----------------
% Beamer Theme Background Layout
% Confirmed in v2.1c(2026/05/20).
% Established in v1.0a(2021/12/03).
% Updated in v1.1a(2021/12/31), v1.2a(2022/03/10), v1.3a(2022/03/16), v1.3c(2024/04/16), v2.1c(2026/05/20).
% ----------------
% 于 v2.1c(2026/05/20) 修改原 Background 选项 (boolean if), 为 Key-Value 形式, 且选项分支只负责定义 \bit@path@<name> 路径宏, 实际 \pgfdeclareimage 在选项配置外统一基于路径是否存在来配置.
% ----------------
% BIT-Full(原 Background=true):: 设置 \bit@path@bg, \bit@path@bgoftitle, \bit@path@bgofsubsectoc.
% BIT-Lite(原 Background=false):: 仅设置 \bit@path@bgoftitle.
% none:: 置空.
% Custom:: 用户通过 \beamer@bit@backgroundextend 自行设置.
% ----------------
% 设置图片路径宏.
\if\EqualOptionsBeamer{Background}{BIT-Full}%
  \def\bit@path@bg{./resources/backgroundoftitlepage(Empty).png}% 空白背景图.
  \def\bit@path@bgoftitle{./resources/backgroundoftitlepage(Empty).png}% 空白背景图.
  \def\bit@path@bgofsubsectoc{./resources/backgroundofsubsectiontocpage.png}% 带 Verify 的背景图.
\else\if\EqualOptionsBeamer{Background}{BIT-Lite}%
  \def\bit@path@bgoftitle{./resources/backgroundoftitlepage(Empty).png}%
\else\if\EqualOptionsBeamer{Background}{Custom}%
  \relax%
\else\if\EqualOptionsBeamer{Background}{none}%
  \relax%
\fi\fi\fi\fi

% 定义图片.
\ifcsname bit@path@bg\endcsname%
  \pgfdeclareimage[width=\paperwidth]{bg}{\bit@path@bg}%
  \usebackgroundtemplate{\pgfuseimage{bg}}% 定义背景为 bg 图片.
\fi
\ifcsname bit@path@bgoftitle\endcsname%
  \pgfdeclareimage[width=\paperwidth]{bgoftitle}{\bit@path@bgoftitle}%
\fi
\ifcsname bit@path@bgofsubsectoc\endcsname%
  \pgfdeclareimage[width=\paperwidth]{bgofsubsectoc}{\bit@path@bgofsubsectoc}%
\fi
\pgfdeclareimage[width=.24\paperwidth]{emblem}{./resources/BITemblem.png}%
\addtobeamertemplate{background}{%
  \ifbeamer@plainframe\else%
    \begin{tikzpicture}[remember picture,overlay]%
      \node[anchor=south east, inner sep=0pt, outer sep=0pt, opacity=0.12]%
        at ([xshift=-5mm,yshift=-22mm]current page.south east) {\pgfuseimage{emblem}};%
    \end{tikzpicture}%
  \fi%
}{}%
