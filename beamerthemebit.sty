  % #3: <可选>模式选择 - 带 * 即不显示区块标题前缀.
  % #4: <可选>后缀 - 标签.
  % #5: 抄录语言.
  % #6: <可选>附加参数 - minted.
  % #7: 文件名.
  % #8: 注释定界符.
	  {\bitcodeinputnocounter}{ O{} m s O{} m O{} m !D''{||} }{%
	  	listing file={./sourcecode/#7},%
	  	listing engine=minted,%
	  	minted language={#5},%
	  	minted options={%
