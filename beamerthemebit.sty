% 定义新的 if.
\newif\ifbeamer@bit@contentmuticols

% KEY:: ColorDisplay [PASSTO:: beamercolorthemebit.sty].
% VALUE:: BITA | BITB.
\DeclareOptionBeamer{ColorDisplay}{\PassOptionsToPackage{ColorDisplay={#1}}{beamercolorthemebit}}
% KEY:: BlockDisplay.
% VALUE:: colorful | followtheme | allgrey.
\DeclareOptionBeamer{BlockDisplay}{\def\beamer@bit@BlockDisplay{#1}}
% KEY:: CodeTheme.
% VALUE:: listing | minted | minted2.
\DeclareOptionBeamer{CodeTheme}{\def\beamer@bit@CodeTheme{#1}}
% KEY:: MintedStyle [BASED:: CodeTheme].
% VALUE:: lightmode | darkmode | <custom>.
\DeclareOptionBeamer{MintedStyle}{\def\beamer@bit@MintedStyle{#1}}
% KEY:: LanguageMode.
% VALUE:: cn | en.
\DeclareOptionBeamer{LanguageMode}{\def\beamer@bit@LanguageMode{#1}}
% KEY:: Miniframes [PASSTO:: beamerouterthemebit.sty].
% VALUE:: follow | separate | none.
\DeclareOptionBeamer{Miniframes}{\PassOptionsToPackage{Miniframes={#1}}{beamerouterthemebit}}
% KEY:: NavigationTool [PASSTO:: beamerouterthemebit.sty].
% VALUE:: none | 1 | 2 | 3 | 1-2 | 1-3 | 2-3 | 1-2-3.
\DeclareOptionBeamer{NavigationTool}{\PassOptionsToPackage{NavigationTool={#1}}{beamerouterthemebit}}
% KEY:: LogoWidth [PASSTO:: beamerouterthemebit.sty].
% VALUE:: <dimen>.
\DeclareOptionBeamer{LogoWidth}{\PassOptionsToPackage{LogoWidth={#1}}{beamerouterthemebit}}
% KEY:: FontTheme [PASSTO:: beamerfontthemebit.sty].
% VALUE:: Auto | Ubuntu | Win | Mac | Fandol | Source-Han | Source-Han(Local) | ZhongYi(Local) | Custom.
\DeclareOptionBeamer{FontTheme}{\PassOptionsToPackage{FontTheme={#1}}{beamerfontthemebit}}
% KEY:: MathFont [PASSTO:: beamerfontthemebit.sty].
% VALUE:: XITS | LM | <custom>.
\DeclareOptionBeamer{MathFont}{\PassOptionsToPackage{MathFont={#1}}{beamerfontthemebit}}
% KEY:: BIBMode.
% VALUE:: biber | none.
\DeclareOptionBeamer{BIBMode}{\def\beamer@bit@BIBMode{#1}}
% KEY:: BIBStyle [BASED:: BIBMode].
% VALUE:: numeric-comp | <custom>.
\DeclareOptionBeamer{BIBStyle}{\def\beamer@bit@BIBStyle{#1}}
\DeclareOptionBeamer{ContentMuticols}{\csname beamer@bit@contentmuticols#1\endcsname}
% KEY:: Background.
% VALUE:: BIT-Full | BIT-Lite | none | Custom.
\DeclareOptionBeamer{Background}{\def\beamer@bit@Background{#1}}
% KEY:: VI.
% VALUE:: BIT | Custom.
\DeclareOptionBeamer{VI}{\def\beamer@bit@VI{#1}}

\ExecuteOptionsBeamer{%
  ColorDisplay=BITA,%
  BlockDisplay=colorful,%
  CodeTheme=listing,%
  LanguageMode=cn,%
  Miniframes=follow,%
  NavigationTool=1-2-3,%
  LogoWidth=48pt,%
  FontTheme=Auto,%
  MathFont=LM,%
  BIBMode=biber,%
  ContentMuticols=true,%
  Background=BIT-Full,%
  VI=BIT%
}
\ProcessOptionsBeamer
\if\EqualOptionsBeamer{CodeTheme}{minted}%
  \ExecuteOptionsBeamer{MintedStyle=lightmode}%
\fi
\if\EqualOptionsBeamer{CodeTheme}{minted2}%
  \ExecuteOptionsBeamer{MintedStyle=lightmode}%
\fi
\if\EqualOptionsBeamer{BIBMode}{biber}%
  \ExecuteOptionsBeamer{BIBStyle=numeric-comp}
\fi
\ProcessOptionsBeamer
