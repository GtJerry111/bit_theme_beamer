\fi\fi

% 颜色主题 - bit.
\usecolortheme{bit}
% 外部主题 - bit.
\useoutertheme{bit}
% 内部主题 - bit.
\useinnertheme{bit}
% 字体主题 - bit.
\usefonttheme{bit}
% 取消 itemize 环境编号.
\setbeamertemplate{itemize items}[square]
