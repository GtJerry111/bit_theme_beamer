% ----------------
% Declare of Options
% Confirmed in v2.1c(2026/05/20).
% Established in v2.1c(2026/05/20).
% ----------------
% CMD:: \DeclareOptionBeamer  - 声明参数.
% CMD:: \ExecuteOptionsBeamer - 预执行参数.
% CMD:: \ProcessOptionsBeamer - 处理参数.
% ----------------
% KEY:: FontTheme.
% VALUE:: Auto | Ubuntu | Win | Mac | Fandol | Source-Han | Source-Han(Local) | ZhongYi(Local) | Custom.
\DeclareOptionBeamer{FontTheme}{\def\beamer@bit@FontTheme{#1}}
% KEY:: MathFont.
% VALUE:: XITS | LM | <custom>.
\DeclareOptionBeamer{MathFont}{\def\beamer@bit@MathFont{#1}}

\ExecuteOptionsBeamer{
  FontTheme=Auto,%
  MathFont=LM%
}
\ProcessOptionsBeamer
% ----------------


% ----------------
% Beamer Theme Font Layout
% ----------------
% Confirmed in v2.1c(2026/05/20).
% Established in v1.0a(2021/12/03).
% Updated in v1.1a(2021/12/31), v1.2a(2022/03/10), v1.3d(2024/05/18), v2.1b(2025/10/06), v2.1c(2026/05/20).
% ----------------
% 于 v1.2a(2022/03/10) 设置主题数学字体选项 MathFont.
% 于 v2.1c(2026/05/20) 从主主题文件独立, 设置 FontTheme 与 MathFont 选项. 定义 FontTheme(系统/字体包/本地/Custom) 与 MathFont(含<custom>) 两类参数, 可按需切换 sans/mono/CJK 字体族. 补充 Latin Modern Mono 字体的 Italic 字形为 Slanted, 补齐 Latin Modern Sans 的 Small Caps 字形 (使用 NewComputerModern, 部分涉及 FakeBold), 补齐 Helvetica 的 Small Caps 字形 (使用 TeX Gyre Heros, 没有 Mac 测试我随便补了个 TeX 自带的近似字体).
% ----------------
% 自动检测操作系统 (Auto), 无需手动设置.
\if\EqualOptionsBeamer{FontTheme}{Auto}%
  \IfFileExists{/Library/Keychains/System.keychain}{%
    \def\beamer@bit@FontTheme{Mac}%
  }{%
    \IfFileExists{C:/Windows/System32/cmd.exe}{%
      \def\beamer@bit@FontTheme{Win}%
    }{%
      \def\beamer@bit@FontTheme{Ubuntu}%
    }%
  }%
\fi

% 主字体(无衬线) / CJK 字体设置.
%% 参考::
%% https://tex.stackexchange.com/questions/468795
\if\EqualOptionsBeamer{FontTheme}{Ubuntu}%
  \setsansfont{Roboto}%                                sans      - Roboto
  \setmonofont{Ubuntu Mono}%                           mono      - Ubuntu Mono
  \ctexset{fontset=ubuntu}%                            CJK       - 思源黑体(CTeX)
  \setCJKsansfont{Noto Sans CJK SC}%                   CJKsans   - 思源黑体(简体中文)
    [%
      ItalicFont = {AR PL KaitiM GB}%                  (italic)  - 文鼎楷体
    ]%
\else\if\EqualOptionsBeamer{FontTheme}{Win}%
  \setsansfont{Segoe UI}%                              sans      - Segoe UI
  \setmonofont{Consolas}%                              mono      - Consolas
  \ctexset{fontset=windows}%                           CJK       - 微软雅黑(CTeX)
  \setCJKsansfont{Microsoft YaHei}%                    CJKsans   - 微软雅黑
    [%
      BoldFont   = {* Bold},%                          (bold)    - 微软雅黑 Bold
      ItalicFont = {KaiTi}%                            (italic)  - 楷体
    ]%
\else\if\EqualOptionsBeamer{FontTheme}{Mac}%
  \setsansfont{Helvetica}%                             sans      - Helvetica
  \setmonofont{Menlo}%                                 mono      - Menlo
  \IfFontExistsTF{Songti SC}{%
    \setCJKmainfont{Songti SC}%                          CJKmain   - 宋体(简体中文)
      [%
        BoldFont   = {Songti SC Bold}%                   (bold)    - 宋体 Bold
      ]%
  }{%
    \setCJKmainfont{STSong}%                            CJKmain   - 宋体替代
  }%
  \IfFontExistsTF{PingFang SC}{%
    \setCJKsansfont{PingFang SC}%                        CJKsans   - 苹方(简体中文)
      [%
        BoldFont       = {PingFang SC Medium}%           (bold)    - 苹方中粗
      ]%
    \setCJKmonofont{PingFang SC}%                        CJKmono   - 苹方(简体中文)
  }{%
    \IfFontExistsTF{Heiti SC}{%
      \setCJKsansfont{Heiti SC}%                         CJKsans   - 黑体(简体中文)
        [%
          BoldFont = {Heiti SC Medium}%
        ]%
      \setCJKmonofont{Heiti SC}%                         CJKmono   - 黑体(简体中文)
    }{%
      \setCJKsansfont{Hiragino Sans GB}%                 CJKsans   - 冬青黑体(简体中文)
      \setCJKmonofont{Hiragino Sans GB}%                 CJKmono   - 冬青黑体(简体中文)
    }%
  }%
\else\if\EqualOptionsBeamer{FontTheme}{Fandol}%
  \setsansfont{Latin Modern Sans}%                     sans      - Latin Modern Sans
    [%
      UprightFeatures = {%
        SmallCapsFont = {NewCMSans10-Regular},%        (sc)      - New Computer Modern Sans Regular
        SmallCapsFeatures = {Letters = SmallCaps}%
      },%
      ItalicFeatures = {%
        SmallCapsFont = {NewCMSans08-Oblique},%        (it-sc)   - New Computer Modern Sans Oblique
        SmallCapsFeatures = {Letters = SmallCaps}%
      },%
      BoldFeatures = {%
        SmallCapsFont = {NewCMSans10-Regular},%        (bold-sc) - New Computer Modern Sans Regular(FakeBold)
        SmallCapsFeatures = {Letters = SmallCaps, FakeBold = 3.6}%
      },%
      BoldItalicFeatures = {%
        SmallCapsFont = {NewCMSans08-Oblique},%        (bf-itsc) - New Computer Modern Sans Oblique(FakeBold)
        SmallCapsFeatures = {Letters = SmallCaps, FakeBold = 2.8}%
      }%
    ]%
  \setmonofont{Latin Modern Mono}%                     mono      - Latin Modern Mono
    [%
      ItalicFont = {Latin Modern Mono Slanted}%        (italic)  - Latin Modern Mono Slanted
    ]%
  \ctexset{fontset=fandol}%                            CJK       - Fandol(CTeX)
  \setCJKsansfont{FandolHei}%                          CJKsans   - FandolHei
    [%
      BoldFont   = {*-Bold},%                          (bold)    - FandolHei Bold
      ItalicFont = {FandolKai}%                        (italic)  - FandolKai
    ]%
\else\if\EqualOptionsBeamer{FontTheme}{Source-Han}%
  \setsansfont{Latin Modern Sans}%                     sans      - Latin Modern Sans
    [%
      UprightFeatures = {%
        SmallCapsFont = {NewCMSans10-Regular},%        (sc)      - New Computer Modern Sans Regular
        SmallCapsFeatures = {Letters = SmallCaps}%
      },%
      ItalicFeatures = {%
        SmallCapsFont = {NewCMSans08-Oblique},%        (it-sc)   - New Computer Modern Sans Oblique
        SmallCapsFeatures = {Letters = SmallCaps}%
      },%
      BoldFeatures = {%
        SmallCapsFont = {NewCMSans10-Regular},%        (bold-sc) - New Computer Modern Sans Regular(FakeBold)
        SmallCapsFeatures = {Letters = SmallCaps, FakeBold = 3.6}%
      },%
      BoldItalicFeatures = {%
        SmallCapsFont = {NewCMSans08-Oblique},%        (bf-itsc) - New Computer Modern Sans Oblique(FakeBold)
        SmallCapsFeatures = {Letters = SmallCaps, FakeBold = 2.8}%
      }%
    ]%
  \setmonofont{Latin Modern Mono}%                     mono      - Latin Modern Mono
    [%
      ItalicFont = {Latin Modern Mono Slanted}%        (italic)  - Latin Modern Mono Slanted
    ]%
  \setCJKsansfont{Source Han Sans SC}%                 CJKsans   - 思源黑体(简体中文)
    [%
      ItalicFont = {LXGW WenKai Medium}%               (italic)  - 霞鹜文楷 Medium
    ]%
  \setCJKmonofont{LXGW WenKai Medium}%                 CJKmono   - 霞鹜文楷
\else\if\EqualOptionsBeamer{FontTheme}{Source-Han(Local)}%
  \setsansfont{Latin Modern Sans}%                     sans      - Latin Modern Sans
    [%
      UprightFeatures = {%
        SmallCapsFont = {NewCMSans10-Regular},%        (sc)      - New Computer Modern Sans Regular
        SmallCapsFeatures = {Letters = SmallCaps}%
      },%
      ItalicFeatures = {%
        SmallCapsFont = {NewCMSans08-Oblique},%        (it-sc)   - New Computer Modern Sans Oblique
        SmallCapsFeatures = {Letters = SmallCaps}%
      },%
      BoldFeatures = {%
        SmallCapsFont = {NewCMSans10-Regular},%        (bold-sc) - New Computer Modern Sans Regular(FakeBold)
        SmallCapsFeatures = {Letters = SmallCaps, FakeBold = 3.6}%
      },%
      BoldItalicFeatures = {%
        SmallCapsFont = {NewCMSans08-Oblique},%        (bf-itsc) - New Computer Modern Sans Oblique(FakeBold)
        SmallCapsFeatures = {Letters = SmallCaps, FakeBold = 2.8}%
      }%
    ]%
  \setmonofont{Latin Modern Mono}%                     mono      - Latin Modern Mono
    [%
      ItalicFont = {Latin Modern Mono Slanted}%        (italic)  - Latin Modern Mono Slanted
    ]%
  \setCJKsansfont{SourceHanSansSC-Regular.otf}%        CJKsans   - 思源黑体(简体中文)
    [%
      Path       = "fonts/,"%
      BoldFont   = {SourceHanSansSC-Bold.otf},%        (bold)    - 思源黑体 Bold
      ItalicFont = {LXGWWenKai-Medium.ttf}%            (italic)  - 霞鹜文楷 Medium
    ]%
  \setCJKmonofont{LXGWWenKai-Medium.ttf}%              CJKmono   - 霞鹜文楷 Medium
    [Path = "fonts/,"]%
\else\if\EqualOptionsBeamer{FontTheme}{ZhongYi(Local)}%
  \setsansfont{Latin Modern Sans}%                     sans      - Latin Modern Sans
    [%
      UprightFeatures = {%
        SmallCapsFont = {NewCMSans10-Regular},%        (sc)      - New Computer Modern Sans Regular
        SmallCapsFeatures = {Letters = SmallCaps}%
      },%
      ItalicFeatures = {%
        SmallCapsFont = {NewCMSans08-Oblique},%        (it-sc)   - New Computer Modern Sans Oblique
        SmallCapsFeatures = {Letters = SmallCaps}%
      },%
      BoldFeatures = {%
        SmallCapsFont = {NewCMSans10-Regular},%        (bold-sc) - New Computer Modern Sans Regular(FakeBold)
        SmallCapsFeatures = {Letters = SmallCaps, FakeBold = 3.6}%
      },%
      BoldItalicFeatures = {%
        SmallCapsFont = {NewCMSans08-Oblique},%        (bf-itsc) - New Computer Modern Sans Oblique(FakeBold)
        SmallCapsFeatures = {Letters = SmallCaps, FakeBold = 2.8}%
      }%
    ]%
  \setmonofont{Latin Modern Mono}%                     mono      - Latin Modern Mono
    [%
      ItalicFont = {Latin Modern Mono Slanted}%        (italic)  - Latin Modern Mono Slanted
    ]%
  \setCJKsansfont{simhei.ttf}%                         CJKsans   - 黑体
    [%
      Path       = "fonts/,"%
      ItalicFont = {simkai.ttf}%                       (italic)  - 楷体
    ]%
  \setCJKmonofont{simfang.ttf}%                        CJKmono   - 仿宋
    [Path = "fonts/,"]%
\else\if\EqualOptionsBeamer{FontTheme}{Custom}%
  \ifcsname beamer@bit@fontextend\endcsname%
    \beamer@bit@fontextend%
  \else%
    \PackageError{beamerfontthemebit}{%
      Option [FontTheme=Custom] is loaded. %
      To extend the theme, define the command \string\beamer@bit@fontextend}%
  \fi%
\fi\fi\fi\fi\fi\fi\fi\fi

% 数学字体设置.
\if\EqualOptionsBeamer{MathFont}{XITS}%
  \setmathfont{XITS Math}%                         math      - XITS
\else\if\EqualOptionsBeamer{MathFont}{LM}%
  \setmathfont{latinmodern-math.otf}%              math      - Latin Modern
\else\if\EqualOptionsBeamer{MathFont}{\beamer@bit@MathFont}%
  \edef\set@MathFont{\noexpand%
    \setmathfont{\beamer@bit@MathFont}}%
  \set@MathFont%
\fi\fi\fi
% ----------------


\mode<presentation>


% ----------------
% Beamer Theme Font Style Layout
% ----------------
% Confirmed in v2.1c(2026/05/20).
% Established in v1.1a(2021/12/03).
% ----------------
% 于 v2.1c(2026/05/20) 从主主题文件独立.
% ----------------
% 幻灯标题字体设置.
\setbeamerfont{frametitle}{size=\large,series=\bfseries}
\setbeamerfont{framesubtitle}{size=\scriptsize,series=\bfseries}
% 封页字体设置.
\setbeamerfont{title}{size=\LARGE,series=\bfseries}
\setbeamerfont{subtitle}{size=\small,series=\bfseries}
\setbeamerfont{author}{size=\small,series=\bfseries}
\setbeamerfont{date}{size=\footnotesize,series=\bfseries}

\setbeamerfont{block title}{size=\normalsize}
\setbeamerfont{structure}{size=\normalsize,series=\bfseries}
% 脚注字号设置.
\setbeamerfont{footnote}{size=\scriptsize}
% 页眉页脚字体设置.
\setbeamerfont{section in head/foot}{size=\scriptsize,series=\bfseries}
\setbeamerfont{subsection in head/foot}{size=\scriptsize,series=\bfseries}
\setbeamerfont{institute in head/foot}{size=\scriptsize,series=\bfseries}
\setbeamerfont{author in head/foot}{size=\tiny,series=\mdseries}
\setbeamerfont{title in head/foot}{size=\tiny,series=\bfseries}
\setbeamerfont{framenumber in head/foot}{size=\scriptsize,series=\bfseries}
% itemize 环境序号设置.
% \setbeamertemplate{itemize item}{\scriptsize\raise1.25pt\hbox{\textbullet}}
% \setbeamertemplate{itemize subitem}{\scriptsize\raise1.25pt\hbox{\textbullet}}
% \setbeamertemplate{itemize subsubitem}{\scriptsize\raise1.25pt\hbox{\textbullet}}
% ----------------


